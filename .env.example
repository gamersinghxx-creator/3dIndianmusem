# Copy this file to .env.local and fill in your Neon connection string.
# .env.local is gitignored and must never be committed.

# Neon Postgres (pooled connection string from the Neon dashboard)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Optional: a direct (non-pooled) URL for migrations / drizzle-kit
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
